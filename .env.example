# ════════════════════════════════════════════════════════════════
#  BoomStroy Telegram Bot — Muhit o'zgaruvchilari (namuna)
#  Bu faylni `.env` ga nusxalang va o'z qiymatlaringizni kiriting.
#  ⚠️  HAQIQIY tokenlar/kalitlarni hech qachon git ga joylamang!
# ════════════════════════════════════════════════════════════════

# ===== TELEGRAM =====
BOT_TOKEN=123456789:YOUR_TELEGRAM_BOT_TOKEN
BOT_USERNAME=BoomStroyBot
# Bir nechta admin: vergul bilan ajrating (id1,id2)
ADMIN_TELEGRAM_ID=000000000
# (ixtiyoriy) Buyurtmalar yuboriladigan guruh id si
ADMIN_GROUP_ID=

# ===== KANAL (majburiy obuna) =====
CHANNEL_USERNAME=@boomstroyqurilishsavdo
CHANNEL_LINK=https://t.me/boomstroyqurilishsavdo

# ===== FIREBASE =====
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# ===== SERVER =====
PORT=3000
WEBHOOK_URL=https://YOUR_APP.railway.app
NODE_ENV=production

# ===== SAYT / ALOQA =====
SITE_URL=https://boomstroyshop.netlify.app
ADMIN_PANEL_URL=https://boomstroyshop.netlify.app
SUPPORT_PHONE=+998 94 217 10 10
SUPPORT_USERNAME=@boomstroy_support
SUPPORT_EMAIL=info@boomstroy.uz

# ===== DELIVERY SETTINGS =====
BASE_DELIVERY_FEE=10000
DELIVERY_PER_KM=2000
MAX_DELIVERY_KM=50
WAREHOUSE_LAT=41.299496
WAREHOUSE_LNG=69.240073
WAREHOUSE_NAME=Asosiy Ombor (Toshkent)
# Asosiy ombordan borib olish uchun manzil/telefon (ixtiyoriy)
WAREHOUSE_ADDRESS=
WAREHOUSE_PHONE=

# ===== PAYMENT =====
CARD_NUMBER=8600000000000000
CARD_OWNER=BoomStroy LLC

# ===== LOYALTY / BONUS =====
# 1 ball = qancha so'm (100 ball = 1 000 so'm => 10)
LOYALTY_POINT_VALUE=10
# Xariddan ball qaytimi koeffitsienti (0.002 ≈ 2% naqd qiymatli cashback)
LOYALTY_EARN_RATE=0.002
# Referal bonuslari (ball)
REFERRAL_BONUS_POINTS=500
REFERRAL_WELCOME_POINTS=200
